---
import Layout from '../layouts/Layout.astro';

const HEADSHOT = 'https://media.licdn.com/dms/image/v2/D5603AQHj6aIHE45IcQ/profile-displayphoto-shrink_200_200/profile-displayphoto-shrink_200_200/0/1683128840744?e=1778716800&v=beta&t=fNY_WLce5zWLG-369V4EyVk0YTs9bzK7_z2UFL5CWyE';

const programs = [
  {
    name: 'AI Foundations for Business Teams',
    format: 'Half-day workshop',
    badge: 'Most popular',
    badgeType: 'green',
    capacity: 'Teams of 5–20',
    mode: 'On-site or remote',
    desc: 'The fastest way to get a non-technical team genuinely using AI. Covers the mental models that make AI click, the tools worth using, and the prompting habits that separate mediocre from remarkable results. Hands-on throughout — participants leave with real outputs, not just awareness.',
    outcomes: [
      'Understand what AI can and can\'t do — without the hype',
      'Write prompts that get consistently useful outputs',
      'Identify 3–5 tasks you can hand off to AI this week',
      'Avoid the most common AI mistakes that waste time',
    ],
  },
  {
    name: 'Prompt Engineering for Professionals',
    format: 'Full-day workshop',
    badge: null,
    capacity: 'Teams of 5–15',
    mode: 'On-site or remote',
    desc: 'A full-day deep dive into getting dramatically better results from any AI model — Claude, GPT, Gemini, or enterprise LLMs. Covers chain-of-thought prompting, structured outputs, persona design, context management, and evaluation. For anyone whose work involves producing content, analysis, or code with AI assistance.',
    outcomes: [
      'Master advanced prompting patterns used by AI researchers',
      'Build reusable prompt templates for your most common tasks',
      'Evaluate AI output quality — and know when not to trust it',
      'Adapt techniques across different AI tools and models',
    ],
  },
  {
    name: 'AI Workflow Design Sprint',
    format: '2-day intensive',
    badge: 'High impact',
    badgeType: 'amber',
    capacity: 'Teams of 3–8',
    mode: 'On-site preferred',
    desc: 'A structured two-day sprint that maps your current workflows, identifies the highest-leverage AI opportunities, and ends with a working prototype. Think of it as an AI audit and build session combined. Ideal for teams with a specific bottleneck to solve — or leaders who want a clear picture of where AI fits before investing further.',
    outcomes: [
      'Full map of your team\'s current processes and time costs',
      'Prioritized list of AI opportunities ranked by impact and effort',
      'At least one working AI workflow prototype',
      '90-day AI adoption roadmap your team can own',
    ],
  },
  {
    name: 'Executive AI Briefing',
    format: '1:1 · By arrangement',
    badge: null,
    capacity: '1–4 executives',
    mode: 'In-person or call',
    desc: 'A private session for C-suite leaders and board members who need a grounded, unbiased view of the AI landscape. Covers how to evaluate vendor claims, what questions to ask before buying, how to assess your team\'s readiness, and what a realistic AI capability-building plan looks like for your business.',
    outcomes: [
      'Clear-eyed view of what AI can deliver — and what it can\'t',
      'Framework for evaluating AI vendors without getting bamboozled',
      'Org readiness assessment and gap identification',
      'Concrete next steps tailored to your situation',
    ],
  },
];

const audiences = [
  { icon: '👥', title: 'Business teams', desc: 'Sales, marketing, operations, HR, support — anyone who spends time on repetitive writing, research, or communication. AI can give you hours back each week.' },
  { icon: '🏢', title: 'Executives & leaders', desc: 'CEOs, VPs, and department heads who need to make decisions about AI investment, vendor selection, and organizational capability — without getting lost in the weeds.' },
  { icon: '🔧', title: 'Builders & product teams', desc: 'Developers, designers, and product managers who want to integrate AI into what they build — covering APIs, prompt design, evaluation, and responsible deployment.' },
];

const steps = [
  { num: '1', title: 'Free intro call', desc: '30 minutes to understand your team, your goals, your tools, and where AI might genuinely help. If we\'re not the right fit, you\'ll leave with useful direction anyway.' },
  { num: '2', title: 'Scoped proposal', desc: 'We recommend the right format and depth for your situation — no upselling to programs you don\'t need. Custom agenda sent for your review before booking.' },
  { num: '3', title: 'Tailored delivery', desc: 'Training uses your real tools, your actual workflows, and examples from your industry. Participants work with AI during the session, not just listen to slides about it.' },
  { num: '4', title: 'Follow-through support', desc: 'Two weeks of follow-up access via email for questions that come up after the session. We want the training to actually stick.' },
];
---

<Layout
  title="AI Training — Louis Roehrs"
  description="Practical AI training for business teams, executives, and builders. Workshops, prompt engineering, and AI workflow design from Louis Roehrs, founder of TeleTrex."
  activePage="AI Training"
>

  <!-- HERO -->
  <div class="page-hero">
    <div class="hero-left">
      <div class="eyebrow eyebrow-accent">AI Training</div>
      <h1>AI skills your team will actually <em>use tomorrow</em></h1>
      <p class="hero-sub">No jargon. No slide decks about the future of humanity. Just practical skills, real tools, and workflows that make your team faster starting the day after training ends.</p>
      <div class="hero-btns">
        <a href="https://calendly.com/roehrs-ai/30min" target="_blank" rel="noopener noreferrer" class="btn-accent">Book a free intro call ↗</a>
        <a href="#programs" class="btn-ghost">See programs</a>
      </div>
    </div>

    <div class="hero-right">
      <p class="pain-label">Sound familiar?</p>
      <div class="pain-grid">
        <div class="pain-card">
          <div class="pain-q">"We bought AI tools but no one uses them."</div>
          <div class="pain-a">Adoption gaps are training problems. We fix the why before the what.</div>
        </div>
        <div class="pain-card">
          <div class="pain-q">"Our prompts give mediocre results."</div>
          <div class="pain-a">Most people use 10% of what AI can do. We show you the other 90%.</div>
        </div>
        <div class="pain-card">
          <div class="pain-q">"I don't know where AI fits in our workflow."</div>
          <div class="pain-a">We map your actual processes and find the highest-leverage spots.</div>
        </div>
      </div>
      <div class="pull-quote">
        <p>"No pressure pitch. If we're not the right fit, we'll say so. The intro call is genuinely free."</p>
        <cite>— Louis Roehrs, Founder · TeleTrex</cite>
      </div>
    </div>
  </div>

  <!-- BIO STRIP -->
  <div class="trainer-strip">
    <img src={HEADSHOT} alt="Louis Roehrs" class="trainer-photo" />
    <p class="trainer-bio">
      <strong>Louis Roehrs</strong> built IBM Watson Trend — the DAA Award-winning AI app featured in USA Today — and led AI incubator teams at IBM before founding <strong>TeleTrex</strong>. He has spoken at <strong>IBM Think conferences</strong> on AI-Powered Search, holds <strong>4 US patents</strong> in AI and location intelligence, and has spent two decades turning cutting-edge AI research into tools that real people use. His training is built on what actually works, not what looks good on a slide. &nbsp;<a href="https://linkedin.com/in/louisroehrs" target="_blank" rel="noopener noreferrer">linkedin.com/in/louisroehrs ↗</a>
    </p>
  </div>

  <!-- AUDIENCE -->
  <section class="section on-white">
    <div class="section-header">
      <div class="eyebrow">Audience</div>
      <h2 class="section-title">Who this training is for</h2>
      <p class="section-sub">Programs are tailored to each group — technical depth when it helps, plain language when it doesn't.</p>
    </div>
    <div class="audience-grid">
      {audiences.map(a => (
        <div class="audience-card">
          <div class="audience-icon">{a.icon}</div>
          <div class="audience-title">{a.title}</div>
          <div class="audience-desc">{a.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROGRAMS -->
  <section id="programs" class="section on-surface">
    <div class="section-header">
      <div class="eyebrow">Programs</div>
      <h2 class="section-title">Training programs</h2>
      <p class="section-sub">From a half-day team workshop to a multi-day intensive — choose the format that fits your goals and timeline.</p>
    </div>
    <div class="programs-list">
      {programs.map(p => (
        <div class="program-row">
          <div class="program-left">
            <div class="program-name">{p.name}</div>
            <div class="program-tags">
              <span class="tag tag-blue">{p.format}</span>
              {p.badge && <span class={`tag tag-${p.badgeType ?? 'blue'}`}>{p.badge}</span>}
            </div>
          </div>
          <div class="program-center">
            <p class="program-desc">{p.desc}</p>
            <ul class="program-outcomes">
              {p.outcomes.map(o => <li>{o}</li>)}
            </ul>
          </div>
          <div class="program-right">
            <div class="program-meta">{p.capacity}</div>
            <div class="program-meta">{p.mode}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section on-white">
    <div class="section-header">
      <div class="eyebrow">How it works</div>
      <h2 class="section-title">The training approach</h2>
      <p class="section-sub">Every engagement is custom-built for your team. Here's how it typically goes.</p>
    </div>
    <div class="approach-grid">
      {steps.map(s => (
        <div class="approach-item">
          <div class="approach-num">{s.num}</div>
          <div>
            <div class="approach-title">{s.title}</div>
            <div class="approach-desc">{s.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- BOOKING BANNER -->
  <div class="booking-banner">
    <div>
      <h2>Ready to get your team using AI <em>for real?</em></h2>
      <p>Start with a free 30-minute intro call. No pitch deck, no pressure. We'll talk through what's slowing you down and whether training is actually the right solution.</p>
    </div>
    <div class="booking-btns">
      <a href="https://calendly.com/roehrs-ai/30min" target="_blank" rel="noopener noreferrer" class="btn-accent">Book a free intro call ↗</a>
      <a href="https://teletrex.com" target="_blank" rel="noopener noreferrer" class="btn-ghost">Explore TeleTrex</a>
      <div class="booking-note">Free · 30 min · No commitment</div>
    </div>
  </div>

</Layout>

<style>
  /* HERO */
  .page-hero {
    display: grid; grid-template-columns: 1fr 1fr;
    background: var(--navy); padding: 72px 56px;
    gap: 56px; align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .hero-left h1 {
    font-family: var(--font-serif);
    font-size: 42px; font-weight: 700;
    color: #F0F6FC; line-height: 1.12;
    letter-spacing: -0.5px; margin: 16px 0 20px;
  }
  .hero-left h1 em { font-style: italic; color: var(--navy-mid); }
  .hero-sub { font-size: 16px; color: var(--navy-mid); line-height: 1.75; margin-bottom: 32px; }
  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero-right { display: flex; flex-direction: column; gap: 16px; }
  .pain-label { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--ink-muted); }
  .pain-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
  .pain-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px;
  }
  .pain-q { font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 6px; line-height: 1.4; font-style: italic; }
  .pain-a { font-size: 11px; color: var(--ink-muted); line-height: 1.6; }
  .pull-quote {
    background: var(--surface); border: 1px solid var(--border);
    border-left: 3px solid var(--accent); border-radius: 10px; padding: 16px 20px;
  }
  .pull-quote p  { font-size: 13px; color: var(--ink-mid); font-style: italic; line-height: 1.6; margin-bottom: 6px; }
  .pull-quote cite { font-size: 11px; color: var(--ink-muted); font-style: normal; }

  /* BIO STRIP */
  .trainer-strip {
    background: var(--surface); border-bottom: 1px solid var(--border);
    padding: 32px 56px; display: flex; gap: 24px; align-items: center;
  }
  .trainer-photo {
    width: 64px; height: 64px; border-radius: 50%;
    object-fit: cover; object-position: center top;
    border: 2px solid var(--border-mid); flex-shrink: 0;
  }
  .trainer-bio { font-size: 14px; color: var(--ink-mid); line-height: 1.7; }
  .trainer-bio strong { color: var(--ink); font-weight: 500; }
  .trainer-bio a { color: var(--navy-light); text-decoration: none; font-size: 13px; }
  .trainer-bio a:hover { text-decoration: underline; }

  /* AUDIENCE */
  .audience-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .audience-card {
    background: var(--surface-card); border: 1px solid var(--border);
    border-radius: 12px; padding: 22px;
  }
  .audience-icon  { font-size: 22px; margin-bottom: 10px; }
  .audience-title { font-size: 14px; font-weight: 500; color: var(--ink); margin-bottom: 6px; }
  .audience-desc  { font-size: 13px; color: var(--ink-mid); line-height: 1.6; }

  /* PROGRAMS */
  .programs-list {
    background: var(--surface-card); border: 1px solid var(--border);
    border-radius: 14px; padding: 0 28px;
  }
  .program-row {
    display: grid; grid-template-columns: 260px 1fr 140px;
    gap: 28px; align-items: start;
    padding: 28px 0; border-bottom: 1px solid var(--border);
  }
  .program-row:last-child { border-bottom: none; }
  .program-name { font-size: 16px; font-weight: 500; color: var(--ink); margin-bottom: 10px; }
  .program-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .program-desc { font-size: 14px; color: var(--ink-mid); line-height: 1.7; margin-bottom: 14px; }
  .program-outcomes { list-style: none; }
  .program-outcomes li {
    font-size: 13px; color: var(--ink-mid); padding: 4px 0;
    padding-left: 16px; position: relative; line-height: 1.5;
  }
  .program-outcomes li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 12px; }
  .program-right {}
  .program-meta { font-size: 12px; color: var(--ink-muted); margin-bottom: 4px; }

  /* APPROACH */
  .approach-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .approach-item {
    display: flex; gap: 16px; align-items: flex-start;
    background: var(--surface-card); border: 1px solid var(--border);
    border-radius: 12px; padding: 20px;
  }
  .approach-num {
    font-family: var(--font-serif); font-size: 28px; font-weight: 700;
    color: var(--navy-pale); line-height: 1; flex-shrink: 0; min-width: 28px;
  }
  .approach-title { font-size: 14px; font-weight: 500; color: var(--ink); margin-bottom: 4px; }
  .approach-desc  { font-size: 13px; color: var(--ink-mid); line-height: 1.6; }

  /* BOOKING BANNER */
  .booking-banner {
    background: var(--navy); padding: 56px;
    display: grid; grid-template-columns: 1fr auto;
    gap: 40px; align-items: center;
  }
  .booking-banner h2 {
    font-family: var(--font-serif); font-size: 30px; font-weight: 700;
    color: #F0F6FC; margin-bottom: 10px; letter-spacing: -0.3px;
  }
  .booking-banner h2 em { font-style: italic; color: var(--navy-mid); }
  .booking-banner p { font-size: 15px; color: var(--navy-mid); line-height: 1.7; max-width: 520px; }
  .booking-btns { display: flex; flex-direction: column; gap: 10px; align-items: flex-end; flex-shrink: 0; }
  .booking-note { font-size: 12px; color: var(--navy-mid); text-align: right; margin-top: 4px; }

  @media (max-width: 900px) {
    .page-hero    { grid-template-columns: 1fr; padding: 48px 24px; }
    .pain-grid    { grid-template-columns: 1fr; }
    .trainer-strip { padding: 28px 24px; flex-direction: column; align-items: flex-start; }
    .audience-grid { grid-template-columns: 1fr; }
    .program-row  { grid-template-columns: 1fr; }
    .approach-grid { grid-template-columns: 1fr; }
    .booking-banner { grid-template-columns: 1fr; padding: 40px 24px; }
    .booking-btns { align-items: flex-start; }
  }
</style>
