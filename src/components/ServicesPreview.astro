<section class="section on-surface">
  <div class="two-col">

    <!-- SPEAKING -->
    <div>
      <div class="section-header">
        <div class="eyebrow">Speaking</div>
        <h2 class="section-title">On stage</h2>
        <p class="section-sub">IBM Think speaker on AI-Powered Search. Available for conferences, keynotes, and panels.</p>
      </div>
      <div class="panel">
        <div class="panel-header">Topics</div>
        <div class="list-item">
          <div class="list-dot"></div>
          <div>
            <div class="list-item-title">AI-Powered Search</div>
            <div class="list-item-sub">How cognitive AI transforms enterprise information retrieval and knowledge discovery — as delivered at IBM Think.</div>
            <span class="tag tag-amber" style="margin-top:6px;">IBM Think · Keynote</span>
          </div>
        </div>
        <div class="list-item">
          <div class="list-dot"></div>
          <div>
            <div class="list-item-title">Scaling businesses with practical AI</div>
            <div class="list-item-sub">Lessons from building Watson-era products and founding TeleTrex.</div>
          </div>
        </div>
        <div class="list-item">
          <div class="list-dot"></div>
          <div>
            <div class="list-item-title">Human–AI collaboration in practice</div>
            <div class="list-item-sub">How to build organizations that get the most from both humans and AI.</div>
          </div>
        </div>
        <div class="panel-footer"><a href="/speaking">Full speaking page →</a></div>
      </div>
    </div>

    <!-- TRAINING -->
    <div>
      <div class="section-header">
        <div class="eyebrow">Training</div>
        <h2 class="section-title">AI training</h2>
        <p class="section-sub">Practical, no-jargon AI training for business teams, executives, and builders.</p>
      </div>
      <div class="panel">
        <div class="panel-header">Programs</div>
        <div class="list-item">
          <div class="list-dot"></div>
          <div>
            <div class="list-item-title">AI Foundations for Business Teams</div>
            <div class="list-item-sub">Prompting, tools, and workflows that save time starting today.</div>
            <span class="tag tag-blue" style="margin-top:6px;">Workshop · Half-day</span>
          </div>
        </div>
        <div class="list-item">
          <div class="list-dot"></div>
          <div>
            <div class="list-item-title">Prompt Engineering for Professionals</div>
            <div class="list-item-sub">From basics to advanced techniques for dramatically better AI outputs.</div>
            <span class="tag tag-blue" style="margin-top:6px;">Workshop · Full-day</span>
          </div>
        </div>
        <div class="list-item">
          <div class="list-dot"></div>
          <div>
            <div class="list-item-title">Executive AI Briefing</div>
            <div class="list-item-sub">Evaluate vendors, build internal capability, cut through the hype.</div>
            <span class="tag tag-blue" style="margin-top:6px;">1:1 · By arrangement</span>
          </div>
        </div>
        <div class="panel-footer"><a href="/training">Full training page →</a></div>
      </div>
    </div>

  </div>
</section>

<style>
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  @media (max-width: 900px) {
    .two-col { grid-template-columns: 1fr; }
  }
</style>
